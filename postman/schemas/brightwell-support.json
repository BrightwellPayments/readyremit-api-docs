      "post": {
        "tags": ["Zendesk (Customer Scoped)"],
        "summary": "Add ticket comment",
        "description": "Add a comment to a support ticket. Available to customer-scoped API clients. Attach previously uploaded files by including their tokens in the `uploads` array.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["comment"],
                "properties": {
                  "comment": {
                    "type": "object",
                    "required": ["body"],
                    "properties": {
                      "body": {
                        "type": "string",
                        "description": "Comment text (plain text)"
                      },
                      "html_body": {
                        "type": "string",
                        "description": "Comment text (HTML). Overrides body if provided."
                      },
                      "public": {
                        "type": "boolean",
                        "description": "Whether the comment is visible to the end user. Defaults to true."
                      },
                      "author_id": {
                        "type": "number",
                        "description": "Brightwell Support user ID of the comment author"
                      },
                      "uploads": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "description": "Upload tokens returned by POST /support/uploads"
                      }
                    }
                  }
                }
              }
            }
          },
          "required": true
        },
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "ticketId",
            "required": true,
            "description": "Brightwell Support ticket ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Updated ticket with new comment",
            "content": {
              "application/json": {
                "schema": {
                  "description": "Updated ticket with new comment",
                  "type": "object",
                  "additionalProperties": true
                },
                "example": {
                  "attachments": [
